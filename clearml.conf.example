// Скопируйте этот файл в ~/clearml.conf и заполните секции ниже.
// Основная часть (api.web_server, api.api_server, credentials) генерируется
// автоматически командой `clearml-init` — не переписывайте её руками,
// просто ДОПОЛНИТЕ файл, который она создаст, секцией sdk.aws.s3 ниже.

sdk {
    aws {
        s3 {
            region: ""
            key: ""
            secret: ""
            use_credentials_chain: false
            extra_args: {}

            credentials: [
                {
                    // Тестовый бакет для обкатки (см. инструкцию ClearML-example):
                    host: "api.blackhole2.ai.innopolis.university:443"
                    key: "clearml-example"
                    secret: "clearml-example"
                    multipart: true
                    secure: true
                    verify: true
                }
                // При работе с реальным проектом ЗАМЕНИТЕ key/secret на свои,
                // выданные Куховаренко Антоном для вашего бакета:
                // {
                //     host: "api.blackhole2.ai.innopolis.university:443"
                //     key: "<ВАШ_KEY>"
                //     secret: "<ВАШ_SECRET>"
                //     multipart: true
                //     secure: true
                //     verify: true
                // }
            ]
        }
    }
}
